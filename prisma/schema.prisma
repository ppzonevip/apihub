// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 认证 & 用户 ====================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organizations Organization[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== 组织 & 项目 ====================

model Organization {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")

  owner         User           @relation(fields: [ownerId], references: [id])
  projects      Project[]
  subscriptions Subscription[]

  @@map("organizations")
}

model Project {
  id             String   @id @default(cuid())
  name           String
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  apiRoutes    ApiRoute[]
  apiKeys      ApiKey[]

  @@map("projects")
}

// ==================== API 路由 & Key ====================

model ApiRoute {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  path         String
  upstreamUrl  String   @map("upstream_url")
  method       String   @default("GET")
  rateLimit    Int      @default(1)     // QPS
  monthlyLimit Int      @default(10000) // 每月请求上限
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  usageLogs  UsageLog[]
  apiKeys    ApiKey[]    @relation("RouteApiKeys")

  @@map("api_routes")
}

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique // UUID格式
  name       String
  projectId  String    @map("project_id")
  routeId    String?   @map("route_id")
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  project   Project    @relation(fields: [projectId], references: [id])
  route     ApiRoute?  @relation("RouteApiKeys", fields: [routeId], references: [id])
  usageLogs UsageLog[]

  @@map("api_keys")
}

// ==================== 使用量日志 ====================

model UsageLog {
  id         String   @id @default(cuid())
  apiKeyId   String   @map("api_key_id")
  routeId    String?  @map("route_id")
  statusCode Int      @map("status_code")
  latencyMs  Int      @map("latency_ms")
  bytesIn    Int      @default(0) @map("bytes_in")
  bytesOut   Int      @default(0) @map("bytes_out")
  timestamp  DateTime @default(now())

  apiKey ApiKey   @relation(fields: [apiKeyId], references: [id])
  route  ApiRoute? @relation(fields: [routeId], references: [id])

  @@index([apiKeyId, timestamp])
  @@index([routeId, timestamp])
  @@map("usage_logs")
}

// ==================== 订阅 & 会员 ====================

model Subscription {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  tier           String   @default("free") // 'free' | 'pro' | 'enterprise'
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("subscriptions")
}

// ==================== 枚举映射 ====================
// tier: 'free' | 'pro' | 'enterprise'
// method: GET | POST | PUT | DELETE | PATCH | OPTIONS | HEAD
